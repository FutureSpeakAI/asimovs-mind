# Asimov's Mind — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required for Gemini MCP Server ──────────────────────────────
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Required for Claude Code Plugin ─────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Optional: Override default data directory ────────────────────
# Default: ~/.friday
# FRIDAY_DATA_DIR=/path/to/your/friday/data

# ── Optional: Override Gemini output directory ───────────────────
# Default: ~/Desktop/friday-creations
# FRIDAY_CREATIONS_DIR=/path/to/creations

# ── Optional: Override career-ops directory ──────────────────────
# Default: ./tools/career-ops (relative to this repo)
# CAREER_OPS_DIR=/path/to/career-ops

# ── Optional: OpenRouter for multi-model routing ────────────────
# OPENROUTER_API_KEY=your-openrouter-key-here

# ── Optional: Local LLM (Ollama) ────────────────────────────────
# OLLAMA_HOST=http://127.0.0.1:11434
