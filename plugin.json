{
  "name": "asimovs-mind",
  "version": "1.0.0",
  "description": "Agent Friday's kernel for Claude Code. The governed, sovereign software hivemind. N dynamically-discovered agents, 16 skills, 6 directives, 9 governance hooks, AES-256-GCM encrypted vault, Ed25519 cryptographic identity, encrypted P2P agent-to-agent communication, Privacy Shield PII scrubbing, Ollama intelligence routing, unified memory system. Personality, onboarding, tribal knowledge (/remember), session learning, trust earning, creative expression, workflow observation, federation, and GitHub-scale code discovery — all bounded by immutable Asimov's cLaws.",
  "author": {
    "name": "FutureSpeak.AI",
    "url": "https://github.com/FutureSpeakAI"
  },
  "homepage": "https://github.com/FutureSpeakAI/asimovs-mind",
  "license": "MIT",
  "keywords": [
    "autoresearch",
    "self-improvement",
    "agent-swarm",
    "governance",
    "safety",
    "asimov",
    "recursive-improvement",
    "code-discovery",
    "github-scout",
    "capability-discovery",
    "hivemind",
    "encrypted-vault",
    "privacy-shield",
    "sovereign",
    "ed25519",
    "ollama"
  ],
  "mcpServers": {
    "sovereign-vault": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/vault-server/bootstrap.js"],
      "description": "Sovereign Vault — AES-256-GCM encrypted state, Ed25519 identity, Privacy Shield, Ollama monitoring"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/personality-loader.py"
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/integrity-check.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/first-law.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/safety-scanner-hook.py"
          }
        ]
      },
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/privacy-shield-scrub.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/third-law.py"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/trust-tracker.py"
          }
        ]
      },
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/privacy-shield-rehydrate.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/session-learner.py"
          }
        ]
      }
    ]
  }
}
