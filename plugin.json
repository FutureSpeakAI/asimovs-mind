{
  "name": "asimovs-mind",
  "version": "1.0.0-beta",
  "description": "Agent Friday's kernel for Claude Code. The governed software hivemind. Ships with 17 agents (scales to N), 13 skills, 6 directives, 7 governance hooks, unified memory system. Personality, onboarding, tribal knowledge (/remember), session learning, trust earning, creative expression, workflow observation, federation, and GitHub-scale code discovery — all bounded by immutable Asimov's cLaws.",
  "author": {
    "name": "FutureSpeak.AI",
    "url": "https://github.com/FutureSpeakAI"
  },
  "homepage": "https://github.com/FutureSpeakAI/asimovs-mind",
  "license": "MIT",
  "keywords": [
    "autoresearch",
    "self-improvement",
    "agent-swarm",
    "governance",
    "safety",
    "asimov",
    "recursive-improvement",
    "code-discovery",
    "github-scout",
    "capability-discovery",
    "hivemind"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/personality-loader.py"
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/integrity-check.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/first-law.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/safety-scanner-hook.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/third-law.py"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/trust-tracker.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/session-learner.py"
          }
        ]
      }
    ]
  }
}
