{
  "name": "asimovs-mind",
  "version": "2.3.0",
  "description": "Agent Friday — the complete AI runtime for Claude Code. 17 subsystems, 89 MCP tools, holographic dashboard. Encrypted vault (AES-256-GCM), Ed25519 identity, P2P encrypted channels, Privacy Shield, 3-provider LLM routing, 3-tier memory with semantic search, person-level trust graph, personality evolution with anti-sycophancy calibration, agent delegation with awareness mesh, 9 connectors (72 tools), daily briefings, meeting intelligence, enterprise consent gates, and governance enforced by Asimov's cLaws. Local-first. Sovereign by design.",
  "author": {
    "name": "FutureSpeak.AI",
    "url": "https://github.com/FutureSpeakAI"
  },
  "homepage": "https://github.com/FutureSpeakAI/asimovs-mind",
  "license": "MIT",
  "keywords": [
    "autoresearch",
    "self-improvement",
    "agent-swarm",
    "governance",
    "safety",
    "asimov",
    "recursive-improvement",
    "code-discovery",
    "github-scout",
    "capability-discovery",
    "hivemind",
    "encrypted-vault",
    "privacy-shield",
    "sovereign",
    "ed25519",
    "ollama"
  ],
  "mcpServers": {
    "friday-core": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/friday-core/bootstrap.js"],
      "description": "Agent Friday Runtime — 17 subsystems: vault, identity, privacy, ollama, p2p, llm, memory, context, trust, personality, agents, tools, connectors, gateway, briefing, voice, enterprise"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/personality-loader.py"
          },
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/integrity-check.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/first-law.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/safety-scanner-hook.py"
          }
        ]
      },
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/privacy-shield-scrub.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/third-law.py"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/trust-tracker.py"
          }
        ]
      },
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/privacy-shield-rehydrate.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/session-learner.py"
          }
        ]
      }
    ]
  }
}
